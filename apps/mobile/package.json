  "repository": {
    "type": "git",
    "url": "git+https://github.com/obytes/react-native-template-obytes.git"
  },
  "prettier": "@acme/prettier-config",
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false,
        "exclude": [
          "react-native-restart",
          "i18next"
        ]
      }
    },
    "install": {
      "exclude": [
        "eslint-config-expo"
      ]
    }
  }
