{
  "name": "@acme/admin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm with-env next build",
    "clean": "git clean -xdf .cache .next .turbo node_modules",
    "langgraph-dev": "pnpm with-env npx @langchain/langgraph-cli dev --port 2024 --config ../../langgraph.json",
    "next-dev": "pnpm with-env next dev --turbopack",
    "dev": "pnpm with-env concurrently \"pnpm run langgraph-dev\" \"pnpm run next-dev\"",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "start": "pnpm with-env next start",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@acme/api": "workspace:*",
    "@acme/auth": "workspace:*",
    "@acme/db": "workspace:*",
    "@acme/deep-agents": "workspace:*",
    "@acme/error-handler": "workspace:*",
    "@acme/jobs": "workspace:*",
    "@acme/pusher": "workspace:*",
    "@acme/sandboxes": "workspace:*",
    "@acme/ui": "workspace:*",
    "@acme/validators": "workspace:*",
    "@acme/webhooks": "workspace:*",
    "@langchain/react": "^0.1.3",
    "@t3-oss/env-nextjs": "^0.13.0",
    "@tanstack/react-query": "catalog:",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "@trpc/tanstack-react-query": "catalog:",
    "geist": "^1.3.1",
    "langgraph-nextjs-api-passthrough": "^0.1.4",
    "next": "^16.1.6",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "superjson": "2.2.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:*",
    "@acme/prettier-config": "workspace:*",
    "@acme/tailwind-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "@types/node": "^22.14.1",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^8.0.0",
    "eslint": "catalog:",
    "jiti": "^1.21.7",
    "prettier": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@acme/prettier-config"
}
