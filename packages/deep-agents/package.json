{
  "name": "@acme/deep-agents",
  "version": "0.1.0",
  "private": true,
  "description": "DeepAgents supervisor, sub-agent definitions, middleware, and streaming integration for Magic Vibing AI",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./supervisor": {
      "import": "./src/supervisor/index.ts",
      "types": "./src/supervisor/index.ts"
    },
    "./subagents": {
      "import": "./src/subagents/index.ts",
      "types": "./src/subagents/index.ts"
    },
    "./middleware": {
      "import": "./src/middleware/index.ts",
      "types": "./src/middleware/index.ts"
    },
    "./memory": {
      "import": "./src/memory/index.ts",
      "types": "./src/memory/index.ts"
    },
    "./prompts": {
      "import": "./src/prompts/index.ts",
      "types": "./src/prompts/index.ts"
    },
    "./types": {
      "import": "./src/types.ts",
      "types": "./src/types.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "lint:fix": "eslint . --fix",
    "dev": "pnpm with-env tsc --watch",
    "with-env": "dotenv -e ../../.env --",
    "clean": "git clean -xdf .cache .turbo dist node_modules"
  },
  "dependencies": {
    "@acme/db": "workspace:*",
    "@acme/validators": "workspace:*",
    "@langchain/anthropic": "catalog:",
    "@langchain/langgraph": "catalog:",
    "@langchain/langgraph-checkpoint": "^1.0.0",
    "@langchain/langgraph-sdk": "^1.7.2",
    "deepagents": "^1.6.3",
    "langchain": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "@langchain/core": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@langchain/core": "^0.3.56"
  },
  "pnpm": {
    "overrides": {
      "@langchain/core": "^0.3.56"
    }
  }
}
